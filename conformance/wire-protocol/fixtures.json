    "operation": "trackSchemaFromEvent",
    "input": {
      "eventName": "Large Payload Event",
      "eventProperties": {
        "attribute_01": "value", "attribute_02": "value", "attribute_03": "value",
        "attribute_04": "value", "attribute_05": "value", "attribute_06": "value",
        "attribute_07": "value", "attribute_08": "value", "attribute_09": "value",
        "attribute_10": "value", "attribute_11": "value", "attribute_12": "value",
        "attribute_13": "value", "attribute_14": "value", "attribute_15": "value",
        "attribute_16": "value", "attribute_17": "value", "attribute_18": "value",
        "attribute_19": "value", "attribute_20": "value", "attribute_21": "value",
        "attribute_22": "value", "attribute_23": "value", "attribute_24": "value"
      },
      "streamId": "stream-large"
    },
    "mock_response": { "status": 200, "body": { "samplingRate": 1.0 } },
    "expected_request_body": [
      {
        "apiKey": "test-key",
        "appName": "TestApp",
        "appVersion": "1.0.0",
        "libVersion": "<semver>",
        "env": "dev",
        "libPlatform": "<sdk-platform>",
        "messageId": "<uuid-v4>",
        "streamId": "stream-large",
        "sessionId": "",
        "createdAt": "<iso8601>",
        "samplingRate": 1.0,
        "type": "event",
        "eventName": "Large Payload Event",
        "eventProperties": [
          { "propertyName": "attribute_01", "propertyType": "string" },
          { "propertyName": "attribute_02", "propertyType": "string" },
          { "propertyName": "attribute_03", "propertyType": "string" },
          { "propertyName": "attribute_04", "propertyType": "string" },
          { "propertyName": "attribute_05", "propertyType": "string" },
          { "propertyName": "attribute_06", "propertyType": "string" },
          { "propertyName": "attribute_07", "propertyType": "string" },
          { "propertyName": "attribute_08", "propertyType": "string" },
          { "propertyName": "attribute_09", "propertyType": "string" },
          { "propertyName": "attribute_10", "propertyType": "string" },
          { "propertyName": "attribute_11", "propertyType": "string" },
          { "propertyName": "attribute_12", "propertyType": "string" },
          { "propertyName": "attribute_13", "propertyType": "string" },
          { "propertyName": "attribute_14", "propertyType": "string" },
          { "propertyName": "attribute_15", "propertyType": "string" },
          { "propertyName": "attribute_16", "propertyType": "string" },
          { "propertyName": "attribute_17", "propertyType": "string" },
          { "propertyName": "attribute_18", "propertyType": "string" },
          { "propertyName": "attribute_19", "propertyType": "string" },
          { "propertyName": "attribute_20", "propertyType": "string" },
          { "propertyName": "attribute_21", "propertyType": "string" },
          { "propertyName": "attribute_22", "propertyType": "string" },
          { "propertyName": "attribute_23", "propertyType": "string" },
          { "propertyName": "attribute_24", "propertyType": "string" }
        ]
      }
    ],
    "expected_request_headers": { "content-encoding": "gzip" },
    "expected_promise_outcome": "resolve",
    "notes": "The serialized body exceeds the 1024-byte gzip threshold (SPEC.md §7.3.7). On any gzip-capable runtime — which every conformance harness is — the SDK MUST send it with 'Content-Encoding: gzip'; this fixture asserts that header. The mock server MUST gunzip the body before parsing; the decompressed body MUST match expected_request_body byte-for-byte after format validation, and a 'gzip'-labeled body that fails to gunzip MUST fail the fixture. EXEMPTION: an SDK targeting a runtime with no gzip implementation is exempt from the content-encoding assertion (it must still send a correct uncompressed body) and MUST document the limitation in its README."
  },
